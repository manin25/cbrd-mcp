# CBRD MCP Server - Environment Variables
# Copy this file to .env and fill in values

# API key for authenticating MCP clients (required in production)
CBRD_API_KEY=your-secret-api-key-here

# CDP browser URL (Lightpanda in production, optional for local dev)
CBRD_CDP_URL=http://127.0.0.1:9222

# Server port (default: 8080)
PORT=8080

# Set to "true" to use local Chromium instead of Lightpanda (for local dev on Windows/Mac)
CBRD_USE_CHROMIUM=false
